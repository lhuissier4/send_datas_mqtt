# Broker Mosquitto (dockerisé)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WEBSOCKET_PORT=19001
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_QOS=1

# Prefixe des topics : topic final = {MQTT_TOPIC_PREFIX}/{id_machine}/{capteur}
MQTT_TOPIC_PREFIX=usine/iot

# Fichier de donnees a rejouer (une ligne JSON = un instant)
JSONL_PATH=datas/gold/mqtt_iot_plc_send.jsonl

# Intervalle entre chaque ligne (en secondes)
SEND_INTERVAL_SECONDS=2

# InfluxDB (dockerisée) : deux instances separees, une par bucket/flux
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminadmin

INFLUXDB_LIVE_HOST=localhost
INFLUXDB_LIVE_PORT=8086
INFLUXDB_LIVE_TOKEN=iot-live-token
INFLUXDB_LIVE_ORG=iot
INFLUXDB_BUCKET_LIVE=sensor_live

INFLUXDB_STAGING_HOST=localhost
INFLUXDB_STAGING_PORT=8087
INFLUXDB_STAGING_TOKEN=iot-staging-token
INFLUXDB_STAGING_ORG=iot
INFLUXDB_BUCKET_STAGING=sensor_staging

# Job d'export Parquet (Script B)
PARQUET_FLUSH_INTERVAL_MINUTES=5
PARQUET_OUTPUT_DIR=./bdd/parquet
PARQUET_FLUSH_SAFETY_MARGIN_SECONDS=30

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_PORT=5433
