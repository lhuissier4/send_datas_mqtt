# Broker Mosquitto (dockerisé)
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_WEBSOCKET_PORT=19001
MQTT_USERNAME=
MQTT_PASSWORD=
# MQTT_KEEPALIVE=60
# MQTT_QOS=1

# Prefixe des topics : topic final = {MQTT_TOPIC_PREFIX}/{id_machine}/{capteur}
MQTT_TOPIC_PREFIX=usine/iot

# Fichier de donnees a rejouer (une ligne JSON = un instant)
JSONL_PATH=datas/gold/mqtt_iot_plc_send.jsonl

# Intervalle entre chaque ligne (en secondes)
SEND_INTERVAL_SECONDS=2

# InfluxDB 3 Core (dockerisée) : deux instances separees, une par base/flux.
# Pas d'org/bucket (concepts InfluxDB 2) : juste une base + un token admin.
# Le token n'est adopte qu'au tout premier demarrage (volume de donnees
# vide) : pour le changer, il faut aussi supprimer le volume correspondant.
# INFLUXDB_LIVE_HOST=localhost
# INFLUXDB_LIVE_PORT=8183
INFLUXDB_DATABASE_LIVE=sensor_live
INFLUXDB_LIVE_TOKEN=apiv3_mspr2-live-dev-token
# Intervalle de flush groupe du live monitor (Script A) vers InfluxDB : chaque
# write_lp coute ~1s (intervalle de flush WAL d'InfluxDB 3 Core), donc les
# points recus sont bufferises et envoyes groupes toutes les N secondes.
# LIVE_FLUSH_INTERVAL_SECONDS=30

# INFLUXDB_STAGING_HOST=localhost
# INFLUXDB_STAGING_PORT=8182
INFLUXDB_DATABASE_STAGING=sensor_staging
INFLUXDB_STAGING_TOKEN=apiv3_mspr2-staging-dev-token
# Retention de la base staging : purge automatique des points deja exportes
# en Parquet (pas de suppression par predicat en InfluxDB 3 Core).
# INFLUXDB_STAGING_RETENTION=24h

# Job d'export Parquet (Script B)
PARQUET_FLUSH_INTERVAL_MINUTES=5
# PARQUET_OUTPUT_DIR=./bdd/parquet
# PARQUET_FLUSH_SAFETY_MARGIN_SECONDS=30

# Script de correlation sensor_data (parquet) / alerte (InfluxDB live) : ne
# traite que les fichiers parquet dont la fenetre se situe dans les N
# derniers jours.
# CORRELATE_SENSOR_ALERTE_WINDOW_DAYS=180

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
# POSTGRES_PORT=5433

