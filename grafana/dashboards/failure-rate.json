    {
      "id": 1,
      "type": "table",
      "title": "Pannes par machine",
      "description": "Nombre d'episodes d'alerte et taux de panne (temps en alerte / duree de la fenetre) par machine, sur la periode selectionnee.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://mspr2-influxdb-live:8181/api/v3/query_sql",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"db\":\"sensor_live\",\"q\":\"SELECT id_machine, count(*) AS nb_pannes, sum(fin_alerte/1000000000.0 - extract(epoch from time)) AS temps_arret_secondes, sum(fin_alerte/1000000000.0 - extract(epoch from time)) / (($__to - $__from)/1000.0) * 100 AS temps_arret_pct FROM alerte WHERE time >= to_timestamp_millis($__from) AND time <= to_timestamp_millis($__to) GROUP BY id_machine ORDER BY temps_arret_pct DESC\"}",
            "headers": [{ "key": "Accept", "value": "application/json" }]
          },
          "root_selector": "",
          "columns": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "temps_arret_pct" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "decimals", "value": 2 }, { "id": "displayName", "value": "Taux de panne" }] },
          { "matcher": { "id": "byName", "options": "temps_arret_secondes" }, "properties": [{ "id": "unit", "value": "secondes" }, { "id": "displayName", "value": "Temps d'arret" }] }
        ]
      }
    },
