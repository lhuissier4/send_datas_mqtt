{
  "uid": "mspr2-failure-rate",
  "title": "Taux de panne",
  "tags": ["mspr2", "alerte"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1y", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Pannes par machine",
      "description": "Nombre d'episodes d'alerte et taux de panne (temps en alerte / duree de la fenetre) par machine, sur la periode selectionnee.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://mspr2-influxdb-live:8181/api/v3/query_sql",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"db\":\"sensor_live\",\"q\":\"SELECT id_machine, count(*) AS nb_pannes, sum(fin_alerte/1000000000.0 - extract(epoch from time)) AS downtime_seconds, sum(fin_alerte/1000000000.0 - extract(epoch from time)) / (($__to - $__from)/1000.0) * 100 AS downtime_pct FROM alerte WHERE time >= to_timestamp_millis($__from) AND time <= to_timestamp_millis($__to) GROUP BY id_machine ORDER BY downtime_pct DESC\"}",
            "headers": [{ "key": "Accept", "value": "application/json" }]
          },
          "root_selector": "",
          "columns": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "downtime_pct" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "decimals", "value": 2 }] },
          { "matcher": { "id": "byName", "options": "downtime_seconds" }, "properties": [{ "id": "unit", "value": "s" }] }
        ]
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Pannes par type de machine",
      "description": "Meme donnee, agregee par type de machine (CNC, presse, robot...) via la table Postgres machine/type_machine.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "datasource", "uid": "-- Mixed --" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://mspr2-influxdb-live:8181/api/v3/query_sql",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"db\":\"sensor_live\",\"q\":\"SELECT id_machine, count(*) AS nb_pannes, sum(fin_alerte/1000000000.0 - extract(epoch from time)) AS downtime_seconds FROM alerte WHERE time >= to_timestamp_millis($__from) AND time <= to_timestamp_millis($__to) GROUP BY id_machine\"}",
            "headers": [{ "key": "Accept", "value": "application/json" }]
          },
          "root_selector": "",
          "columns": []
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "mspr2-postgres-business" },
          "format": "table",
          "rawSql": "SELECT m.id_machine, tm.type_machine FROM machine m JOIN type_machine tm ON m.id_type_machine = tm.id",
          "rawQuery": true
        }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "id_machine", "mode": "outer" } },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "type_machine": { "operation": "groupby" },
              "nb_pannes": { "operation": "aggregate", "aggregations": ["sum"] },
              "downtime_seconds": { "operation": "aggregate", "aggregations": ["sum"] }
            }
          }
        }
      ]
    }
  ]
}
