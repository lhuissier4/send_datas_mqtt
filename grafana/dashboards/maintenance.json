    {
      "id": 1,
      "type": "table",
      "title": "Maintenance par machine",
      "description": "Frequence et duree des episodes de maintenance par machine, sur la periode selectionnee.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "mspr2-influxdb-live-infinity" },
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://mspr2-influxdb-live:8181/api/v3/query_sql",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"db\":\"sensor_live\",\"q\":\"SELECT id_machine, count(*) AS nb_maintenances, sum(fin_panne/1000000000.0 - extract(epoch from time)) AS total_duration_seconds, avg(fin_panne/1000000000.0 - extract(epoch from time)) AS avg_duration_seconds FROM maintenance WHERE time >= to_timestamp_millis($__from) AND time <= to_timestamp_millis($__to) GROUP BY id_machine ORDER BY nb_maintenances DESC\"}",
            "headers": [{ "key": "Accept", "value": "application/json" }]
          },
          "root_selector": "",
          "columns": []
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "total_duration_seconds" }, "properties": [{ "id": "unit", "value": "secondes" }] },
          { "matcher": { "id": "byName", "options": "avg_duration_seconds" }, "properties": [{ "id": "unit", "value": "secondes" }] }
        ]
      }
    },
